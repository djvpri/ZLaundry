# Database Railway PostgreSQL
# Ambil dari Railway dashboard > klik service PostgreSQL > Connect tab
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# NextAuth
# Generate dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-random-yang-panjang"
NEXTAUTH_URL="http://localhost:3000"

# Di production Railway, NEXTAUTH_URL diisi domain Railway kamu:
# NEXTAUTH_URL="https://laundrykas-production.up.railway.app"
