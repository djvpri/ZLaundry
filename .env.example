# Database Railway PostgreSQL
# Ambil dari Railway dashboard > klik service PostgreSQL > Connect tab > copy DATABASE_URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# NextAuth
# Generate dengan: openssl rand -base64 32
# Atau pakai: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="ganti-dengan-secret-random-yang-panjang"

# Production
NEXTAUTH_URL="https://zlaundry-production.up.railway.app"
